---
// Header left: kitn logo + top nav (Docs · Components · Examples).
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = (p: string) => `${base}/${p.replace(/^\//, '')}`;
const logo = href('kitn-logo.png');
const nav = [
  { label: 'Docs', to: 'guides/introduction' },
  { label: 'Components', to: 'components/artifact' },
  { label: 'Patterns', to: 'patterns/compose-your-own' },
  { label: 'Examples', to: 'examples/drop-in-chat' },
];
---
<div class="flex items-center gap-7">
  <a href={base} class="flex items-center gap-2 no-underline">
    <img src={logo} alt="" width="26" height="24" class="kc-logo-img h-6 w-[26px] shrink-0" />
    <span class="text-xl font-black tracking-tight text-ink">kitn</span>
  </a>
  <nav class="hidden items-center gap-5 md:flex" aria-label="Primary">
    {nav.map((n) => (
      <a href={href(n.to)} class="text-sm font-semibold text-ink-2 no-underline transition-colors hover:text-ink">{n.label}</a>
    ))}
  </nav>
</div>
