---
// Header right: GitHub + an "Ask AI" pill (kitn's own <kc-chat> would power it).
import { Icon } from 'astro-icon/components';
---
<div class="flex items-center gap-3">
  <a href="https://github.com/kitn-ai/chat" target="_blank" rel="noopener" aria-label="GitHub"
     class="flex items-center text-ink-2 transition-colors hover:text-ink">
    <Icon name="lucide:github" class="size-[18px]" />
  </a>
  <button type="button"
    class="inline-flex h-8 cursor-pointer appearance-none items-center justify-center gap-1.5 rounded-full border-0 bg-brand px-3.5 text-sm font-bold text-white transition-[filter] hover:brightness-110">
    <Icon name="lucide:sparkles" class="size-4 shrink-0" />
    <span class="leading-none">Ask AI</span>
  </button>
</div>
