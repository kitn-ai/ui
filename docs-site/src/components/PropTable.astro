---
// Props + events from the kit's generated, no-drift element-meta.json.
import meta from '../data/element-meta.json';
import TypeCell, { isComplexType, simplifyType } from './TypeCell.tsx';
interface Props { tag: string }
const { tag } = Astro.props;
const el = (meta as any[]).find((e) => e.tag === tag);
const props = el?.props ?? [];

const th = 'text-left text-xs font-semibold uppercase tracking-wide text-ink-3 bg-surface px-4 py-2.5 border-b border-line';
---
<div class="not-content my-4 overflow-hidden rounded-xl border border-line">
  <table class="w-full border-collapse text-sm">
    <thead><tr><th class={th}>Property</th><th class={th}>Type</th><th class={th}>Default</th><th class={th}>Notes</th></tr></thead>
    <tbody>
      {props.map((p: any) => {
        const t = simplifyType(p.displayType ?? p.type ?? '');
        return (
          <tr class="border-b border-line last:[&>td]:border-0">
            <td class="px-4 py-3 align-top font-mono text-sm font-semibold text-ink border-b border-line"><span>{p.name}</span></td>
            <td class="px-4 py-3 align-top font-mono text-sm text-link border-b border-line">
              {p.typeName
                ? <TypeCell client:visible label={p.typeName} type={simplifyType(p.typeShape ?? t)} name={p.name} import={p.typeImport} />
                : isComplexType(t)
                  ? <TypeCell client:visible type={t} name={p.name} />
                  : <span>{t}</span>}
            </td>
            <td class="px-4 py-3 align-top font-mono text-sm text-ink-3 border-b border-line">{p.default ?? '—'}</td>
            <td class="px-4 py-3 align-top text-sm text-ink-2 border-b border-line">{p.description}</td>
          </tr>
        );
      })}
    </tbody>
  </table>
</div>
