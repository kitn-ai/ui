---
// Events for an element, from the generated element-meta.json.
import meta from '../data/element-meta.json';
import TypeCell, { isComplexType, simplifyType } from './TypeCell.tsx';
interface Props { tag: string }
const { tag } = Astro.props;
const el = (meta as any[]).find((e) => e.tag === tag);
const events = el?.events ?? [];
const th = 'text-left text-xs font-semibold uppercase tracking-wide text-ink-3 bg-surface px-4 py-2.5 border-b border-line';
---
<div class="not-content my-4 overflow-hidden rounded-xl border border-line">
  <table class="w-full border-collapse text-sm">
    <thead><tr><th class={th}>Event</th><th class={th}>Detail</th><th class={th}>Notes</th></tr></thead>
    <tbody>
      {events.map((ev: any) => {
        const d = simplifyType(ev.displayDetail ?? ev.detail ?? '');
        return (
          <tr>
            <td class="border-b border-line px-4 py-3 align-top font-mono text-sm font-semibold text-link">{ev.name}</td>
            <td class="border-b border-line px-4 py-3 align-top font-mono text-sm text-ink-2">
              {d && isComplexType(d) ? <TypeCell client:visible type={d} name={ev.name} /> : <span>{d || '—'}</span>}
            </td>
            <td class="border-b border-line px-4 py-3 align-top text-sm text-ink-2">{ev.description}</td>
          </tr>
        );
      })}
    </tbody>
  </table>
</div>
