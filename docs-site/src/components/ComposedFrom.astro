---
// Advanced: the SolidJS parts this element wraps, from element-meta.json's
// `composedFrom`. The escape hatch when the element's props aren't enough —
// drop to the Solid layer and compose the pieces yourself.
import meta from '../data/element-meta.json';
interface Props { tag: string }
const { tag } = Astro.props;
const el = (meta as any[]).find((e) => e.tag === tag);
const parts = el?.composedFrom ?? [];
---
{parts.length > 0 && (
  <div class="not-content my-4">
    <p class="mb-3 text-sm text-ink-3">
      This element wraps these SolidJS components — reach for them directly when you need finer control than the props expose.
    </p>
    <div class="flex flex-wrap gap-2">
      {parts.map((p: any) => (
        <span class="inline-flex items-center gap-1.5 rounded-lg border border-line bg-surface px-2.5 py-1.5 font-mono text-[13px] text-ink-2">
          <span class="size-1.5 rounded-full bg-brand"></span>{p.name}
        </span>
      ))}
    </div>
  </div>
)}
