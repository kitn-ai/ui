---
// Styleable ::part()s for an element, from the generated element-meta.json.
// Each part carries a copy-pasteable styling recipe.
import meta from '@kitn.ai/ui/element-meta.json';
import { Code } from '@astrojs/starlight/components';
interface Props { tag: string }
const { tag } = Astro.props;
const el = (meta as any[]).find((e) => e.tag === tag);
const parts = el?.parts ?? [];
const th = 'text-left text-xs font-semibold uppercase tracking-wide text-ink-3 bg-surface px-4 py-2.5 border-b border-line';
---
{parts.length > 0 && (
  <div class="not-content my-4 overflow-hidden rounded-xl border border-line">
    <table class="w-full border-collapse text-sm">
      <thead><tr><th class={th}>Part</th><th class={th}>Purpose</th><th class={th}>Example</th></tr></thead>
      <tbody>
        {parts.map((p: any) => (
          <tr>
            <td class="border-b border-line px-4 py-3 align-top font-mono text-sm font-semibold text-link">{p.name}</td>
            <td class="border-b border-line px-4 py-3 align-top text-sm text-ink-2">{p.doc}</td>
            <td class="border-b border-line px-4 py-3 align-top text-sm">
              {p.recipe ? <Code code={p.recipe} lang="css" /> : <span class="text-ink-3">—</span>}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}
